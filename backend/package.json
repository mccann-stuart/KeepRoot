{
	"name": "backend",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"build": "node ./scripts/dashboard.mjs build",
		"build:dashboard": "node ./scripts/dashboard.mjs build",
		"deploy": "node ./scripts/cloudflare.mjs deploy",
		"dev": "node ./scripts/cloudflare.mjs dev",
		"provision": "node ./scripts/cloudflare.mjs provision",
		"start": "node ./scripts/cloudflare.mjs dev",
		"test": "npm run build:dashboard && vitest run --config vitest.config.mts && vitest run --config vitest.dashboard.config.mts",
		"test:dashboard": "npm run build:dashboard && vitest run --config vitest.dashboard.config.mts",
		"test:worker": "npm run build:dashboard && vitest run --config vitest.config.mts",
		"watch:dashboard": "node ./scripts/dashboard.mjs watch",
		"cf-typegen": "node ./scripts/cloudflare.mjs types",
		"db:migrate:local": "wrangler d1 migrations apply KEEPROOT_DB --local",
		"db:migrate:remote": "wrangler d1 migrations apply KEEPROOT_DB --remote"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@types/node": "^25.4.0",
		"@types/turndown": "^5.0.6",
		"esbuild": "^0.27.3",
		"jsdom": "^26.1.0",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.72.0"
	},
	"dependencies": {
		"@cloudflare/workers-oauth-provider": "^0.3.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"@mozilla/readability": "^0.6.0",
		"@simplewebauthn/browser": "^13.3.0",
		"@simplewebauthn/server": "^13.3.0",
		"agents": "^0.7.6",
		"dompurify": "^3.3.0",
		"fast-xml-parser": "^5.5.5",
		"linkedom": "^0.18.12",
		"marked": "^16.3.0",
		"pdfjs-dist": "^5.5.207",
		"postal-mime": "^2.7.3",
		"tslib": "^2.8.1",
		"turndown": "^7.2.2",
		"zod": "^4.3.6"
	}
}
